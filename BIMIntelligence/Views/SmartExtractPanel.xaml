<Window x:Class="BIMIntelligence.Views.SmartExtractPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Extract"
        Width="950" Height="600"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid Margin="16">
        <!-- Phase 1: Category Picker -->
        <Grid x:Name="CategoryPickerGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="Smart Extract"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#1a1a1a"
                       Margin="0,0,0,4"/>

            <TextBlock Grid.Row="1"
                       x:Name="ProjectInfoText"
                       FontSize="12"
                       Foreground="#666666"
                       Margin="0,0,0,12"/>

            <!-- Search Box -->
            <TextBox Grid.Row="2"
                     x:Name="SearchBox"
                     TextChanged="OnSearchChanged"
                     FontSize="13"
                     Padding="8,6"
                     Margin="0,0,0,8"
                     BorderBrush="#d0d0d0"
                     BorderThickness="1">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Tag" Value="Search categories..."/>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- Category List -->
            <ListView Grid.Row="3"
                      x:Name="CategoryListView"
                      MouseDoubleClick="OnCategoryDoubleClick"
                      BorderBrush="#e0e0e0"
                      BorderThickness="1">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Category" Width="350" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Count" Width="100" DisplayMemberBinding="{Binding Count}"/>
                        <GridViewColumn Header="" Width="350">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Border Background="#e8f0fe" CornerRadius="2" Height="16"
                                                HorizontalAlignment="Left"
                                                Width="{Binding BarWidth}"/>
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Footer -->
            <Grid Grid.Row="4" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           x:Name="CategoryStatusText"
                           VerticalAlignment="Center"
                           Foreground="#666666"
                           FontSize="12"/>

                <Button Grid.Column="2"
                        x:Name="ExtractButton"
                        Content="Extract Selected"
                        Click="OnExtractClick"
                        IsEnabled="False"
                        Padding="16,8"
                        FontSize="13"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>

        <!-- Phase 2: Data Grid -->
        <Grid x:Name="DataGridPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with Back button -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                <Button Content="Back"
                        Click="OnBackClick"
                        Padding="12,6"
                        FontSize="12"
                        Background="#f0f0f0"
                        Foreground="#333"
                        BorderThickness="1"
                        BorderBrush="#d0d0d0"
                        Cursor="Hand"
                        Margin="0,0,12,0"/>
                <TextBlock x:Name="DataGridHeader"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#1a1a1a"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Row="1"
                       x:Name="DataGridSubtitle"
                       FontSize="12"
                       Foreground="#666666"
                       Margin="0,0,0,12"/>

            <!-- Dynamic Data Grid -->
            <DataGrid Grid.Row="2"
                      x:Name="ElementDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderBrush="#e0e0e0"
                      BorderThickness="1"
                      RowHeight="32"
                      ColumnHeaderHeight="36"
                      Background="White"
                      AlternatingRowBackground="#f9f9f9">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#f5f5f5"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderBrush" Value="#e0e0e0"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
            </DataGrid>

            <!-- Footer -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           x:Name="DataStatusText"
                           VerticalAlignment="Center"
                           Foreground="#666666"
                           FontSize="12"/>

                <Button Grid.Column="2"
                        Content="Export CSV"
                        Click="OnExportCsvClick"
                        Padding="16,8"
                        FontSize="13"
                        Background="#059669"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="3"
                        Content="Export JSON"
                        Click="OnExportJsonClick"
                        Padding="16,8"
                        FontSize="13"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Window>
