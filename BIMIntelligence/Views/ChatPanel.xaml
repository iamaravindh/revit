<Page x:Class="BIMIntelligence.Views.ChatPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="White">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="BIM AI Assistant"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#1a1a1a"/>
            <TextBlock Text="Ask questions about the building model"
                       FontSize="11"
                       Foreground="#999999"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Chat Messages -->
        <Border Grid.Row="1"
                BorderBrush="#e8e8e8"
                BorderThickness="1"
                CornerRadius="6"
                ClipToBounds="True">
            <ScrollViewer x:Name="ChatScroller"
                          VerticalScrollBarVisibility="Auto"
                          Padding="8">
                <StackPanel x:Name="MessagesPanel"/>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#d0d0d0"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBox x:Name="InputBox"
                         BorderThickness="0"
                         Padding="8,6"
                         FontSize="13"
                         VerticalContentAlignment="Center"
                         KeyDown="OnInputKeyDown"/>
            </Border>

            <Button Grid.Column="1"
                    x:Name="SendButton"
                    Content="Send"
                    Click="OnSendClick"
                    Margin="6,0,0,0"
                    Padding="14,6"
                    FontSize="13"
                    Background="#2563EB"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Page>
